# Nginx reverse proxy — SmartEnneagram Social Factory
# Salve em: /etc/nginx/sites-available/smartenneagram-social
# Ative com: ln -s /etc/nginx/sites-available/smartenneagram-social /etc/nginx/sites-enabled/
# Teste:      nginx -t
# Reload:     systemctl reload nginx
#
# Troque SERVER_NAME pelo seu domínio sslip.io:
#   exemplo: se-social.123-45-67-89.sslip.io
#   (substitua os pontos do IP por hífens)

server {
    listen 80;
    server_name SERVER_NAME;

    # Redireciona pra HTTPS depois do certbot
    # (certbot adiciona esse bloco automaticamente)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name SERVER_NAME;

    # SSL — preenchido pelo certbot
    ssl_certificate     /etc/letsencrypt/live/SERVER_NAME/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/SERVER_NAME/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Headers de segurança
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Robots-Tag "noindex, nofollow" always;

    # Upload size (pra export ZIP / requests grandes)
    client_max_body_size 10M;

    # Proxy pro Next.js na porta 3030
    location / {
        proxy_pass http://127.0.0.1:3030;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # timeouts maiores pra requests de IA (geração pode levar 30-60s)
        proxy_connect_timeout 90s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    # Next.js assets estáticos
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3030;
        expires 365d;
        add_header Cache-Control "public, immutable";
    }
}
